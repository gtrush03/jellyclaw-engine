# =============================================================================
# jellyclaw — environment template
# Copy to .env.local and fill in. .env.local is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Provider keys
# Anthropic direct is the recommended primary provider for prompt caching.
# OpenRouter is supported but has known caching limitations — see
# engine/src/providers/openrouter.ts for the warning list.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# -----------------------------------------------------------------------------
# OpenCode server security
# When jellyclaw spawns the OpenCode HTTP server, this password gates access.
# REQUIRED in Phase 2+. Leaving blank in Phase 0/1 is allowed for local dev only.
# -----------------------------------------------------------------------------
OPENCODE_SERVER_PASSWORD=

# -----------------------------------------------------------------------------
# Telemetry opt-out
# jellyclaw ships with zero telemetry by default. The flag exists only so
# downstream consumers (Genie, jelly-claw) can assert "off" explicitly.
# -----------------------------------------------------------------------------
# JELLYCLAW_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Genie integration
# Set GENIE_ENGINE=jellyclaw in the Genie env to route dispatches here instead
# of `claude -p`. JELLYCLAW_BIN tells Genie where to find the binary.
# -----------------------------------------------------------------------------
GENIE_ENGINE=jellyclaw
JELLYCLAW_BIN=./dist/cli.js

# -----------------------------------------------------------------------------
# Debug
# Levels: trace | debug | info | warn | error | fatal | silent
# -----------------------------------------------------------------------------
JELLYCLAW_LOG_LEVEL=info
# JELLYCLAW_TRACE_DIR=./traces
