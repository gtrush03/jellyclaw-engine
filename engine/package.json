    "gray-matter": "^4.0.3",
    "hono": "latest",
    "ink": "^5",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ipaddr.js": "^2.3.0",
    "opencode-ai": "1.4.5",
