{
  "name": "@jellyclaw/engine-root",
  "private": true,
  "version": "0.0.1",
  "description": "jellyclaw — open-source Claude Code replacement, wraps OpenCode, built for Genie and jelly-claw",
  "type": "module",
  "license": "MIT",
  "author": "George Trushevskiy",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtrush03/jellyclaw-engine.git"
  },
  "bin": {
    "jellyclaw": "./engine/bin/jellyclaw",
    "jellyclaw-serve": "./engine/bin/jellyclaw-serve"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:hook-patch": "bun run scripts/verify-hook-patch.ts",
    "test:scrub-patch": "bun run scripts/verify-scrub-patch.ts",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package --patch-dir patches --error-on-fail",
    "verify:patches": "patch-package --patch-dir patches --dry-run",
    "clean": "rm -rf dist node_modules/.cache",
    "tui": "node engine/dist/cli.js tui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@hono/node-server": "^1",
    "@modelcontextprotocol/sdk": "latest",
    "@openrouter/ai-sdk-provider": "latest",
    "@vscode/ripgrep": "^1.17.1",
    "better-sqlite3": "latest",
    "better-sse": "latest",
    "chokidar": "^4.0",
    "commander": "^12",
    "diff": "^9.0.0",
    "eventsource-parser": "^3",
    "execa": "latest",
    "gray-matter": "^4.0",
    "hono": "latest",
    "ink": "^5",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ipaddr.js": "^2.3.0",
    "opencode-ai": "1.4.5",
    "p-limit": "^6",
    "patch-package": "^8.0.0",
    "pdfjs-dist": "^5.6.0",
    "picomatch": "^4",
    "pino": "latest",
    "pino-pretty": "latest",
    "react": "^18",
    "react-devtools-core": "^7.0.1",
    "tinyglobby": "^0.2.16",
    "turndown": "^7.2.4",
    "undici": "^8.1.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@playwright/mcp": "0.0.41",
    "@types/better-sqlite3": "latest",
    "@types/diff": "^8.0.0",
    "@types/node": "latest",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^18",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "latest",
    "fast-check": "^4.6.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "latest",
    "typescript": "5",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20.6",
    "bun": ">=1.1"
  },
  "workspaces": {
    "packages": [
      "shared",
      "engine",
      "desktop",
      "integration"
    ],
    "catalog": {
      "@effect/opentelemetry": "4.0.0-beta.48",
      "@effect/platform-node": "4.0.0-beta.48",
      "@types/bun": "1.3.11",
      "@types/cross-spawn": "6.0.6",
      "@octokit/rest": "22.0.0",
      "@hono/zod-validator": "0.4.2",
      "ulid": "3.0.1",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "22.13.9",
