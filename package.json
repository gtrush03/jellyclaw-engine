{
  "name": "@jellyclaw/engine-root",
  "private": true,
  "version": "0.0.1",
  "description": "jellyclaw — open-source Claude Code replacement, wraps OpenCode, built for Genie and jelly-claw",
  "type": "module",
  "license": "MIT",
  "author": "George Trushevskiy",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtrush03/jellyclaw-engine.git"
  },
  "bin": {
    "jellyclaw": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package --patch-dir patches --error-on-fail",
    "verify:patches": "patch-package --patch-dir patches --dry-run",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "latest",
    "@opencode-ai/plugin": "latest",
    "@opencode-ai/sdk": "latest",
    "@openrouter/ai-sdk-provider": "latest",
    "@vscode/ripgrep": "^1.17.1",
    "better-sqlite3": "latest",
    "better-sse": "latest",
    "chokidar": "^4.0",
    "diff": "^9.0.0",
    "eventsource-parser": "^3",
    "execa": "latest",
    "gray-matter": "^4.0",
    "hono": "latest",
    "ipaddr.js": "^2.3.0",
    "opencode-ai": "1.4.5",
    "p-limit": "^6",
    "patch-package": "^8.0.0",
    "pdfjs-dist": "^5.6.0",
    "pino": "latest",
    "pino-pretty": "latest",
    "tinyglobby": "^0.2.16",
    "turndown": "^7.2.4",
    "undici": "^8.1.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/better-sqlite3": "latest",
    "@types/diff": "^8.0.0",
    "@types/node": "latest",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "latest",
    "fast-check": "^4.6.0",
    "tsup": "latest",
    "typescript": "5",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20.6",
    "bun": ">=1.1"
  },
  "workspaces": [
    "shared",
    "engine",
    "desktop",
    "integration"
  ],
  "packageManager": "bun@1.1.0"
}
