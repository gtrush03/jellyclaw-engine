{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jellyclaw",
  "version": "0.1.0",
  "identifier": "com.jellyclaw.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src http://127.0.0.1:* ws://127.0.0.1:*"
    },
    "windows": [
      {
        "title": "Jellyclaw",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/jellyclaw"],
    "resources": [],
    "macOS": {
      "entitlements": "Engine.entitlements",
      "hardenedRuntime": true,
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "jellyclaw",
          "cmd": "./binaries/jellyclaw",
          "args": true
        }
      ]
    }
  }
}
