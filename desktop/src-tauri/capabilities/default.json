{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main Jellyclaw window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "core:event:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/jellyclaw", "sidecar": true, "args": true }]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [{ "name": "binaries/jellyclaw", "sidecar": true, "args": true }]
    }
  ]
}
