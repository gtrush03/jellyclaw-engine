@@ -5,7 +6,10 @@ export function formatToolResult(result: ToolResult): string {
     return `Error: ${result.error}`;
   }
   const text = typeof result.output === "string" ? result.output : JSON.stringify(result.output);
-  return text;
+  // SEC-004: redact credential-shaped substrings before the LLM sees them.
